# Development secrets and punch-through overrides only.
# Persistent non-secret preferences belong in config.toml; see config.example.toml.

KUIB_GROQ_API_KEY=

# Provider secrets:
# KUIB_ANTHROPIC_API_KEY=
# KUIB_MODEL_API_KEY=ollama

# Optional operational/path overrides:
# KUIB_CONFIG=/alternate/config.toml
# KUIB_MESH_CONFIG=/alternate/mesh.config.toml
# KUIB_DB_PATH=/alternate/kuib.db
# KUIB_LOG_PATH=/alternate/kuib.log
# KUIB_DAEMON_SOCKET=/alternate/daemon.sock
# KUIB_ENGINE_SOCKET=/alternate/engine.sock

# Temporary preference overrides (config.toml remains the normal home):
# KUIB_MODEL=anthropic/claude-sonnet-4-5
# KUIB_MODEL_BASE_URL=http://localhost:11434/v1
