# kuib environment — copy to .env and adjust. Never commit real .env files.

# Default provider is Groq (when KUIB_MODEL is unset).
KUIB_GROQ_API_KEY=
KUIB_MODEL_ID=llama-3.3-70b-versatile
# Or pin explicitly: KUIB_MODEL=groq/llama-3.3-70b-versatile

# Other providers:
# KUIB_MODEL=anthropic/claude-sonnet-4-5
# KUIB_ANTHROPIC_API_KEY=
# KUIB_MODEL=openai-compatible/gemma4:12b
# KUIB_MODEL_BASE_URL=http://localhost:11434/v1
# KUIB_MODEL_API_KEY=ollama

# KUIB_DAEMON_SOCKET — optional override; defaults to ~/.kuib/daemon.sock (dev: ./dist/daemon.sock)
