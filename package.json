{
  "name": "@kuib-ai/kuib",
  "version": "0.0.1",
  "description": "kuib ai bitch",
  "scripts": {
    "format:modified": "prettier --write $(git ls-files --others --exclude-standard --modified)",
    "format:all": "prettier --write .",
    "lint:all": "eslint",
    "check": "nx run-many --parallel=10 -t typecheck lint format",
    "check:circular": "madge --circular --extensions ts,tsx packages apps",
    "typecheck": "nx run-many -t typecheck --output-style=stream",
    "test": "bun test packages apps",
    "reload": "bun scripts/reload.ts",
    "wireframes": "pnpm --filter @kuib-ai/wireframes dev",
    "design": "./scripts/design-session.sh"
  },
  "keywords": [],
  "author": {
    "url": "https://github.com/roysupriyo10",
    "name": "Supriyo Roy",
    "email": "supriyo@kuib.ai"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuib-ai/kuib"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "engineStrict": true,
  "engines": {
    "node": "25.4.0"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "catalog:",
    "bun": "catalog:",
    "concurrently": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "jiti": "catalog:",
    "lint-staged": "catalog:",
    "madge": "catalog:",
    "nx": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "nx": {
    "includedScripts": [
      "format:all"
    ]
  },
  "dependencies": {
    "@trpc/server": "catalog:"
  }
}
