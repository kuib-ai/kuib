{
  "name": "@kuib-ai/kuib",
  "version": "0.0.1",
  "description": "kuib ai bitch",
  "scripts": {
    "format:modified": "prettier --write $(git ls-files --others --exclude-standard --modified)",
    "format:all": "prettier --write .",
    "lint:all": "eslint",
    "check:circular": "madge --circular --extensions ts,tsx packages apps",
    "typecheck": "nx run-many -t typecheck --parallel=1000 --output-style=stream",
    "test": "bun test packages apps",
    "reload": "bun scripts/reload.ts",
    "wireframes": "pnpm --filter @kuib-ai/wireframes dev",
    "design": "./scripts/design-session.sh"
  },
  "keywords": [],
  "author": {
    "url": "https://github.com/roysupriyo10",
    "name": "Supriyo Roy",
    "email": "supriyo@kuib.ai"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuib-ai/kuib"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engineStrict": true,
  "engines": {
    "node": "25.4.0"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "catalog:",
    "bun": "catalog:",
    "concurrently": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "jiti": "catalog:",
    "lint-staged": "catalog:",
    "madge": "catalog:",
    "nx": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "nx": {
    "includedScripts": [
      "format:all"
    ]
  },
  "dependencies": {
    "@trpc/server": "catalog:"
  }
}
