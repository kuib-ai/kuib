{
  "name": "@kuib-ai/kuib",
  "version": "0.0.1",
  "description": "kuib ai bitch",
  "scripts": {
    "format:modified": "prettier --write $(git ls-files --others --exclude-standard --modified)",
    "format:all": "prettier --write .",
    "lint:all": "eslint",
    "check": "nx run-many --parallel=10 -t typecheck lint format",
    "check:circular": "madge --circular --extensions ts,tsx packages apps",
    "typecheck": "nx run-many -t typecheck --output-style=stream",
    "test": "bun test packages apps",
    "reload": "bun scripts/reload.ts",
    "wireframes": "pnpm --filter @kuib-ai/wireframes dev",
    "design": "./scripts/design-session.sh"
  },
  "keywords": [],
  "author": {
    "url": "https://github.com/roysupriyo10",
    "name": "Supriyo Roy",
    "email": "supriyo@kuib.ai"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuib-ai/kuib"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engineStrict": true,
  "engines": {
    "node": "25.4.0"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "catalog:",
    "bun": "catalog:",
    "concurrently": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "jiti": "catalog:",
    "lint-staged": "catalog:",
    "madge": "catalog:",
    "nx": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "nx": {
    "includedScripts": [
      "format:all"
    ]
  },
  "dependencies": {
    "@trpc/server": "catalog:"
  }
}
