{
  "name": "@kuib-ai/daemon",
  "version": "0.0.1",
  "description": "kuib node-local fs/shell executor (tRPC)",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": {
      "types": "./src/*/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "bun run src/start.daemon/index.ts"
  },
  "dependencies": {
    "@kuib-ai/env": "workspace:*",
    "@kuib-ai/protocol": "workspace:*",
    "@kuib-ai/std": "workspace:*",
    "@trpc/server": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kuib-ai/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "bun-types": "catalog:"
  }
}
