{
  "name": "@kuib/protocol",
  "version": "0.0.1",
  "description": "kuib protocol — schemas, events, and interfaces",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src/gen/*": "./src/gen/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo -b",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "catalog:",
    "@connectrpc/connect": "catalog:",
    "zod": "catalog:"
  },
  "nx": {},
  "devDependencies": {
    "@bufbuild/buf": "catalog:",
    "@bufbuild/protoc-gen-es": "catalog:"
  }
}
