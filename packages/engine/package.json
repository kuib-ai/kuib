{
  "name": "@kuib-ai/engine",
  "version": "0.0.1",
  "description": "kuib engine — agent loop, event log, daemon dispatch",
  "type": "module",
  "imports": {
    "#*": "./src/*/index.ts",
    "#*.ts": "./src/*.ts",
    "#*.json": "./src/*.json"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": {
      "types": "./src/*/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/groq": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/openai-compatible": "catalog:",
    "@kuib-ai/daemon": "workspace:*",
    "@kuib-ai/protocol": "workspace:*",
    "@kuib-ai/std": "workspace:*",
    "@kuib-ai/tools": "workspace:*",
    "@trpc/client": "catalog:",
    "ai": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kuib-ai/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "bun-types": "catalog:"
  }
}
